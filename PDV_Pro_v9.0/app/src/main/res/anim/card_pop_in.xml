<?xml version="1.0" encoding="utf-8"?>
<!-- v9.1.0 - Entrada suave de cartoes: escala + fade (novo recurso, opcional). -->
<set xmlns:android="http://schemas.android.com/apk/res/android"
    android:interpolator="@android:anim/decelerate_interpolator">
    <scale
        android:fromXScale="0.92" android:toXScale="1.0"
        android:fromYScale="0.92" android:toYScale="1.0"
        android:pivotX="50%" android:pivotY="50%"
        android:duration="260" />
    <alpha
        android:fromAlpha="0.0" android:toAlpha="1.0"
        android:duration="260" />
    <translate
        android:fromYDelta="6%p" android:toYDelta="0"
        android:duration="260" />
</set>
