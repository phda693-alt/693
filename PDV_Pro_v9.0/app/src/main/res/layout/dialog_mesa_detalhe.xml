<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/card_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- v6.7.8 - Info de reserva (exibido quando mesa esta reservada) -->
        <LinearLayout
            android:id="@+id/llReservaInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#2A1500"
            android:padding="10dp"
            android:layout_marginBottom="12dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/tvReservaStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="MESA RESERVADA"
                android:textColor="#FF9800"
                android:textSize="14sp"
                android:textStyle="bold"
                android:gravity="center" />

            <TextView
                android:id="@+id/tvReservadoPorInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Reservado por: "
                android:textColor="#FFB74D"
                android:textSize="13sp"
                android:gravity="center"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- Garcom -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Garcom:"
            android:textColor="#00BCD4"
            android:textSize="14sp"
            android:textStyle="bold" />

        <Spinner
            android:id="@+id/spGarcom"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/spinner_bg"
            android:paddingLeft="12dp"
            android:paddingRight="12dp" />

        <!-- Quantidade de pessoas -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Quantidade de Pessoas:"
            android:textColor="#00BCD4"
            android:textSize="14sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etPessoas"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/input_bg"
            android:hint="Ex: 4"
            android:inputType="number"
            android:paddingLeft="12dp"
            android:paddingRight="12dp"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textColorHint="#607D8B" />

        <!-- Adicionar produto -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Adicionar Produto:"
            android:textColor="#00BCD4"
            android:textSize="14sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="4dp"
            android:gravity="center_vertical">

            <Spinner
                android:id="@+id/spProduto"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:background="@drawable/spinner_bg"
                android:paddingLeft="12dp"
                android:paddingRight="12dp" />

            <ImageButton
                android:id="@+id/btnScanProdutoMesa"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginLeft="8dp"
                android:background="@drawable/btn_scanner"
                android:contentDescription="Ler codigo de barras"
                android:padding="10dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_barcode_scan" />
        </LinearLayout>


        <!-- Observacao para cozinha por item -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ObservaÃ§Ã£o para cozinha do item:"
            android:textColor="#00BCD4"
            android:textSize="14sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etObservacaoCozinhaItem"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/input_bg"
            android:gravity="top|start"
            android:hint="Ex: sem cebola, ponto da carne, retirar molho..."
            android:inputType="textMultiLine|textCapSentences"
            android:maxLength="120"
            android:maxLines="3"
            android:minLines="2"
            android:paddingLeft="12dp"
            android:paddingRight="12dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:textColor="#FFFFFF"
            android:textColorHint="#607D8B"
            android:textSize="14sp" />
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="12dp"
            android:gravity="center_vertical">

            <EditText
                android:id="@+id/etQtdProduto"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:background="@drawable/input_bg"
                android:hint="Qtd"
                android:inputType="numberDecimal"
                android:paddingLeft="12dp"
                android:paddingRight="12dp"
                android:text="1"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textColorHint="#607D8B" />

            <Button
                android:id="@+id/btnAddProduto"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:layout_marginLeft="8dp"
                android:background="@drawable/btn_primary"
                android:paddingLeft="16dp"
                android:paddingRight="16dp"
                android:text="Adicionar"
                android:textColor="#FFFFFF"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Lista de produtos na mesa -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Produtos na Mesa:"
            android:textColor="#00BCD4"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerProdutosMesa"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:background="@drawable/item_list_bg"
            android:padding="4dp" />

        <!-- Total -->
        <TextView
            android:id="@+id/tvTotalMesa"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="end"
            android:text="Total: R$ 0,00"
            android:textColor="#FFD700"
            android:textSize="18sp"
            android:textStyle="bold" />

        <!-- v6.7.9 - Botoes de Impressao -->
        <LinearLayout
            android:id="@+id/llBotoesImpressao"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:visibility="gone">

            <Button
                android:id="@+id/btnImprimirPedidoCompleto"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_marginRight="4dp"
                android:background="@drawable/btn_printer"
                android:text="IMPRIMIR PEDIDO COMPLETO"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnImprimirUltimoItem"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_marginLeft="4dp"
                android:background="@drawable/btn_printer"
                android:text="IMPRIMIR ULTIMO ITEM"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- v6.7.8 - Botao Reservar Mesa -->
        <Button
            android:id="@+id/btnReservarMesa"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/btn_gold"
            android:text="RESERVAR MESA"
            android:textColor="@color/white"
            android:textSize="13sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <!-- v6.8.0 - Botao Pronta para Cobranca -->
        <Button
            android:id="@+id/btnProntaCobranca"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/btn_pronta_cobranca"
            android:text="PRONTA P/ COBRANÃ‡A"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <!-- Botao Encaminhar para Pagamento (v6.7.7) -->
        <Button
            android:id="@+id/btnEncaminharPagamento"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/btn_success"
            android:text="ENCAMINHAR P/ PAGAMENTO"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <!-- Botoes de acao -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp"
            android:gravity="center">

            <Button
                android:id="@+id/btnLimparMesa"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_marginRight="4dp"
                android:background="@drawable/btn_danger"
                android:text="Limpar Mesa"
                android:textColor="#FFFFFF"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btnSalvarMesa"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_marginLeft="4dp"
                android:background="@drawable/btn_primary"
                android:text="Salvar"
                android:textColor="#FFFFFF"
                android:textSize="12sp" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
