<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/gradient_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp"
        android:background="@drawable/toolbar_gradient">

        <ImageButton
            android:id="@+id/btnVoltarCardapio"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@android:color/transparent"
            android:src="@android:drawable/ic_menu_revert"
            android:contentDescription="Voltar"
            android:tint="@color/accent_cyan" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Cardapio Digital - QR Code"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginStart="10dp" />

        <Button
            android:id="@+id/btnVerPedidos"
            android:layout_width="wrap_content"
            android:layout_height="38dp"
            android:text="Pedidos"
            android:textColor="@color/white"
            android:textSize="12sp"
            android:textAllCaps="false"
            android:background="@drawable/btn_secondary"
            android:paddingLeft="10dp"
            android:paddingRight="10dp" />

        <Button
            android:id="@+id/btnVoltarQR"
            android:layout_width="wrap_content"
            android:layout_height="38dp"
            android:layout_marginStart="6dp"
            android:text="QR"
            android:textColor="@color/white"
            android:textSize="12sp"
            android:textAllCaps="false"
            android:background="@drawable/btn_primary"
            android:paddingLeft="10dp"
            android:paddingRight="10dp"
            android:visibility="gone" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvStatusQR"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Iniciando servidor..."
        android:textColor="@color/text_secondary"
        android:textSize="12sp"
        android:gravity="center"
        android:padding="8dp"
        android:background="@drawable/card_bg"
        android:visibility="gone" />

    <ScrollView
        android:id="@+id/layoutQRCode"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="18dp"
            android:gravity="center_horizontal">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Gere um QR Code para cada mesa. Os clientes escaneiam e fazem pedidos pelo celular."
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                android:gravity="center"
                android:lineSpacingExtra="4dp"
                android:layout_marginBottom="18dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_bg"
                android:padding="14dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Selecione a mesa"
                    android:textColor="@color/accent_gold"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:letterSpacing="0"
                    android:layout_marginBottom="8dp" />

                <Spinner
                    android:id="@+id/spMesaQR"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/input_bg"
                    android:padding="10dp"
                    android:popupBackground="@color/colorSurface" />
            </LinearLayout>

            <Button
                android:id="@+id/btnGerarQR"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Gerar QR Code"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textAllCaps="false"
                android:background="@drawable/btn_primary"
                android:layout_marginBottom="18dp" />

            <ImageView
                android:id="@+id/imgQRCode"
                android:layout_width="280dp"
                android:layout_height="280dp"
                android:scaleType="fitCenter"
                android:background="@color/white"
                android:padding="12dp"
                android:visibility="gone"
                android:layout_marginBottom="16dp" />

            <TextView
                android:id="@+id/tvUrlCardapio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:gravity="center"
                android:lineSpacingExtra="4dp"
                android:visibility="gone"
                android:layout_marginBottom="18dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_bg"
                android:padding="15dp"
                android:layout_marginTop="6dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Como funciona"
                    android:textColor="@color/accent_cyan"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:letterSpacing="0"
                    android:layout_marginBottom="10dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="1. Selecione a mesa e gere o QR Code\n2. Imprima ou exiba o QR Code na mesa\n3. O cliente escaneia com o celular\n4. O cardapio digital abre no navegador\n5. O cliente escolhe os produtos e faz o pedido\n6. O pedido aparece automaticamente no sistema\n7. Os itens sao adicionados a mesa correspondente"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:lineSpacingExtra="6dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="\nImportante: o celular do cliente deve estar conectado na mesma rede Wi-Fi que o dispositivo com o PDV Pro."
                    android:textColor="@color/accent_gold"
                    android:textSize="12sp"
                    android:textStyle="italic"
                    android:lineSpacingExtra="3dp" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/layoutPedidos"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:visibility="gone">

        <WebView
            android:id="@+id/webViewPedidos"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />
    </LinearLayout>
</LinearLayout>
