<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/gradient_bg"
    android:padding="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Taxa de Entrega por Bairro"
        android:textSize="22sp"
        android:textColor="@color/accent_cyan"
        android:textStyle="bold"
        android:layout_marginBottom="12dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Cadastre os bairros e suas respectivas taxas de entrega. Essas taxas serao aplicadas automaticamente nos pedidos via WhatsApp e nas vendas para entrega."
        android:textColor="@color/text_secondary"
        android:textSize="13sp"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/btnAddBairro"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="+ ADICIONAR BAIRRO"
        android:textColor="@color/white"
        android:textSize="15sp"
        android:textStyle="bold"
        android:background="@drawable/btn_success"
        android:layout_marginBottom="12dp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvBairros"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

</LinearLayout>
