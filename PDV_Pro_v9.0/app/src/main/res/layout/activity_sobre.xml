<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/gradient_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <!-- Icone do App -->
        <ImageView
            android:id="@+id/ivLogoSobre"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:src="@mipmap/ic_launcher"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/circle_logo"
            android:padding="8dp" />

        <!-- Nome do App -->
        <TextView
            android:id="@+id/tvAppNameSobre"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PDV Pro"
            android:textSize="28sp"
            android:textColor="@color/accent_cyan"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <!-- Versao -->
        <TextView
            android:id="@+id/tvVersao"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Versao 8.0.0 - Sistema Completo"
            android:textSize="16sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="32dp" />

        <!-- Card Sobre o Sistema -->
        <LinearLayout
            android:id="@+id/cardSobre"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="20dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sobre o Sistema"
                android:textSize="18sp"
                android:textColor="@color/accent_cyan"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="O PDV Pro e um sistema completo de Ponto de Venda (PDV) desenvolvido para facilitar o gerenciamento de vendas, produtos, clientes, caixa, relatorios e muito mais. Ideal para comercios e pequenas empresas que buscam agilidade e controle no dia a dia."
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:lineSpacingExtra="4dp" />
        </LinearLayout>

        <!-- Card Desenvolvedor -->
        <LinearLayout
            android:id="@+id/cardDesenvolvedor"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="20dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Desenvolvedor"
                android:textSize="18sp"
                android:textColor="@color/accent_cyan"
                android:textStyle="bold"
                android:layout_marginBottom="16dp" />

            <!-- Nome do Desenvolvedor -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_user"
                    android:layout_marginEnd="12dp" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Desenvolvedor"
                        android:textSize="12sp"
                        android:textColor="@color/text_hint" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PHDA"
                        android:textSize="16sp"
                        android:textColor="@color/accent_gold"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/colorDivider"
                android:layout_marginBottom="12dp" />

            <!-- Telefone -->
            <LinearLayout
                android:id="@+id/layoutTelefone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_delivery"
                    android:layout_marginEnd="12dp" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Telefone para Contato"
                        android:textSize="12sp"
                        android:textColor="@color/text_hint" />

                    <TextView
                        android:id="@+id/tvTelefone"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="(85) 98123-7727"
                        android:textSize="16sp"
                        android:textColor="@color/colorSuccess"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/colorDivider"
                android:layout_marginBottom="12dp" />

            <!-- Ano -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_history"
                    android:layout_marginEnd="12dp" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ano"
                        android:textSize="12sp"
                        android:textColor="@color/text_hint" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="2027"
                        android:textSize="16sp"
                        android:textColor="@color/text_primary"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- Rodape -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PHDA - Todos os direitos reservados"
            android:textSize="12sp"
            android:textColor="@color/text_hint"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="24dp" />

        <!-- Botao Voltar -->
        <Button
            android:id="@+id/btnVoltar"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="VOLTAR"
            android:textColor="@color/white"
            android:background="@drawable/btn_primary"
            android:layout_marginBottom="16dp" />

    </LinearLayout>
</ScrollView>
