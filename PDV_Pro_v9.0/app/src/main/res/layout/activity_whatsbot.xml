<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/gradient_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="🤖 Bot WhatsApp"
                android:textSize="24sp"
                android:textColor="@color/accent_cyan"
                android:textStyle="bold" />

            <Switch
                android:id="@+id/switchBotAtivo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:thumbTint="@color/colorSuccess"
                android:trackTint="@color/colorCard" />
        </LinearLayout>

        <!-- Status Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_bg"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:id="@+id/tvBotStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🔴 Bot DESATIVADO"
                android:textSize="16sp"
                android:textColor="@color/colorDanger"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvSessoesAtivas"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Sessoes ativas: 0"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="4dp" />

            <Button
                android:id="@+id/btnPermissao"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/btn_gold"
                android:text="⚙️ Conceder Permissao de Notificacoes"
                android:textColor="@color/black"
                android:textSize="13sp"
                android:textAllCaps="false"
                android:visibility="gone" />
        </LinearLayout>

        <!-- Estatisticas Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_bg"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="📊 Estatisticas"
                android:textSize="16sp"
                android:textColor="@color/accent_cyan"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvEstatisticas"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Carregando..."
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="8dp" />

            <Button
                android:id="@+id/btnResetEstatisticas"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/btn_danger"
                android:text="Resetar"
                android:textColor="@color/white"
                android:textSize="12sp"
                android:textAllCaps="false"
                android:paddingLeft="16dp"
                android:paddingRight="16dp" />
        </LinearLayout>

        <!-- Configuracoes Gerais -->
        <LinearLayout
            android:id="@+id/layoutConfig"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_bg"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="⚙️ Configuracoes Gerais"
                android:textSize="16sp"
                android:textColor="@color/accent_cyan"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Nome da Empresa"
                android:textSize="13sp"
                android:textColor="@color/text_secondary" />

            <EditText
                android:id="@+id/etNomeEmpresa"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:background="@drawable/input_bg"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:hint="Nome da empresa"
                android:textColorHint="@color/text_hint"
                android:paddingLeft="12dp"
                android:paddingRight="12dp"
                android:layout_marginBottom="8dp"
                android:inputType="text" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="4dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Horario Inicio"
                        android:textSize="13sp"
                        android:textColor="@color/text_secondary" />

                    <EditText
                        android:id="@+id/etHorarioInicio"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:background="@drawable/input_bg"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:hint="08:00"
                        android:textColorHint="@color/text_hint"
                        android:paddingLeft="12dp"
                        android:inputType="time" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="4dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Horario Fim"
                        android:textSize="13sp"
                        android:textColor="@color/text_secondary" />

                    <EditText
                        android:id="@+id/etHorarioFim"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:background="@drawable/input_bg"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:hint="18:00"
                        android:textColorHint="@color/text_hint"
                        android:paddingLeft="12dp"
                        android:inputType="time" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Numero Admin (notificacoes)"
                android:textSize="13sp"
                android:textColor="@color/text_secondary" />

            <EditText
                android:id="@+id/etNumeroAdmin"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:background="@drawable/input_bg"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:hint="5511999999999"
                android:textColorHint="@color/text_hint"
                android:paddingLeft="12dp"
                android:paddingRight="12dp"
                android:layout_marginBottom="8dp"
                android:inputType="phone" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="4dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Delay Resposta (seg)"
                        android:textSize="13sp"
                        android:textColor="@color/text_secondary" />

                    <EditText
                        android:id="@+id/etDelayResposta"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:background="@drawable/input_bg"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:hint="2"
                        android:textColorHint="@color/text_hint"
                        android:paddingLeft="12dp"
                        android:inputType="number" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="4dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Max Produtos Catalogo"
                        android:textSize="13sp"
                        android:textColor="@color/text_secondary" />

                    <EditText
                        android:id="@+id/etMaxProdutos"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:background="@drawable/input_bg"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:hint="20"
                        android:textColorHint="@color/text_hint"
                        android:paddingLeft="12dp"
                        android:inputType="number" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- Funcionalidades -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_bg"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🔧 Funcionalidades"
                android:textSize="16sp"
                android:textColor="@color/accent_cyan"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Atender fora do horario"
                    android:textSize="14sp"
                    android:textColor="@color/text_primary" />
                <Switch
                    android:id="@+id/switchAtenderFora"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="📋 Catalogo de Produtos"
                    android:textSize="14sp"
                    android:textColor="@color/text_primary" />
                <Switch
                    android:id="@+id/switchCatalogo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="💰 Consulta de Precos"
                    android:textSize="14sp"
                    android:textColor="@color/text_primary" />
                <Switch
                    android:id="@+id/switchPreco"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>



            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="🛒 Aceitar Pedidos"
                    android:textSize="14sp"
                    android:textColor="@color/text_primary" />
                <Switch
                    android:id="@+id/switchPedidos"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="📄 Enviar Cupom Automatico"
                    android:textSize="14sp"
                    android:textColor="@color/text_primary" />
                <Switch
                    android:id="@+id/switchCupomAuto"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="🔔 Notificar Vendas ao Admin"
                    android:textSize="14sp"
                    android:textColor="@color/text_primary" />
                <Switch
                    android:id="@+id/switchNotificarVenda"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="👥 Responder em Grupos"
                    android:textSize="14sp"
                    android:textColor="@color/text_primary" />
                <Switch
                    android:id="@+id/switchGrupos"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="📇 Apenas Contatos Salvos"
                    android:textSize="14sp"
                    android:textColor="@color/text_primary" />
                <Switch
                    android:id="@+id/switchApenasContatos"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="🖨️ Impressao Automatica Pedidos"
                    android:textSize="14sp"
                    android:textColor="@color/text_primary" />
                <Switch
                    android:id="@+id/switchImpressaoAuto"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="📝 Registrar Logs"
                    android:textSize="14sp"
                    android:textColor="@color/text_primary" />
                <Switch
                    android:id="@+id/switchLog"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>
        </LinearLayout>

        <!-- v5.0.0 - Configuracoes de IA -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_bg"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="\uD83E\uDDE0 Inteligencia Artificial (IA)"
                android:textSize="16sp"
                android:textColor="@color/accent_cyan"
                android:textStyle="bold"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Configure a IA para respostas inteligentes via GPT/OpenAI"
                android:textSize="11sp"
                android:textColor="@color/text_hint"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="\uD83E\uDDE0 Ativar IA"
                    android:textSize="14sp"
                    android:textColor="@color/text_primary" />
                <Switch
                    android:id="@+id/switchIA"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Chave API (OpenAI)"
                android:textSize="13sp"
                android:textColor="@color/text_secondary" />

            <EditText
                android:id="@+id/etIAApiKey"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:background="@drawable/input_bg"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:hint="sk-..."
                android:textColorHint="@color/text_hint"
                android:paddingLeft="12dp"
                android:paddingRight="12dp"
                android:layout_marginBottom="8dp"
                android:inputType="textPassword" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="URL da API"
                android:textSize="13sp"
                android:textColor="@color/text_secondary" />

            <EditText
                android:id="@+id/etIAApiUrl"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:background="@drawable/input_bg"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:hint="https://api.openai.com/v1/chat/completions"
                android:textColorHint="@color/text_hint"
                android:paddingLeft="12dp"
                android:paddingRight="12dp"
                android:layout_marginBottom="8dp"
                android:inputType="textUri" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Modelo IA"
                android:textSize="13sp"
                android:textColor="@color/text_secondary" />

            <EditText
                android:id="@+id/etIAModel"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:background="@drawable/input_bg"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:hint="gpt-4.1-nano"
                android:textColorHint="@color/text_hint"
                android:paddingLeft="12dp"
                android:paddingRight="12dp"
                android:layout_marginBottom="12dp"
                android:inputType="text" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="6dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="\uD83D\uDCA1 Interpretar Intencoes"
                    android:textSize="14sp"
                    android:textColor="@color/text_primary" />
                <Switch
                    android:id="@+id/switchIAIntencao"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="6dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="\uD83D\uDCAC Respostas Inteligentes"
                    android:textSize="14sp"
                    android:textColor="@color/text_primary" />
                <Switch
                    android:id="@+id/switchIARespostas"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="6dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="\uD83C\uDF1F Sugestoes de Produtos"
                    android:textSize="14sp"
                    android:textColor="@color/text_primary" />
                <Switch
                    android:id="@+id/switchIASugestoes"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="\uD83D\uDE4F Detectar Frustracao"
                    android:textSize="14sp"
                    android:textColor="@color/text_primary" />
                <Switch
                    android:id="@+id/switchIAFrustracao"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvIAStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="IA desativada"
                android:textSize="12sp"
                android:textColor="@color/text_hint"
                android:layout_marginTop="8dp" />
        </LinearLayout>

        <!-- Mensagens Personalizadas -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_bg"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="💬 Mensagens Personalizadas"
                android:textSize="16sp"
                android:textColor="@color/accent_cyan"
                android:textStyle="bold"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Use {empresa}, {horario_inicio}, {horario_fim} como variaveis"
                android:textSize="11sp"
                android:textColor="@color/text_hint"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Mensagem de Boas-Vindas"
                android:textSize="13sp"
                android:textColor="@color/text_secondary" />

            <EditText
                android:id="@+id/etMsgBoasVindas"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="100dp"
                android:background="@drawable/input_bg"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:textColorHint="@color/text_hint"
                android:padding="12dp"
                android:layout_marginBottom="12dp"
                android:gravity="top"
                android:inputType="textMultiLine" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Mensagem Fora do Horario"
                android:textSize="13sp"
                android:textColor="@color/text_secondary" />

            <EditText
                android:id="@+id/etMsgAusencia"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="80dp"
                android:background="@drawable/input_bg"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:textColorHint="@color/text_hint"
                android:padding="12dp"
                android:layout_marginBottom="12dp"
                android:gravity="top"
                android:inputType="textMultiLine" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Mensagem de Encerramento"
                android:textSize="13sp"
                android:textColor="@color/text_secondary" />

            <EditText
                android:id="@+id/etMsgEncerramento"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="80dp"
                android:background="@drawable/input_bg"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:textColorHint="@color/text_hint"
                android:padding="12dp"
                android:gravity="top"
                android:inputType="textMultiLine" />
        </LinearLayout>

        <!-- Botoes de Acao -->
        <Button
            android:id="@+id/btnSalvar"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/btn_success"
            android:text="💾 Salvar Configuracoes"
            android:textColor="@color/black"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textAllCaps="false"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnTestarBot"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/btn_primary"
            android:text="🧪 Testar Bot"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:textAllCaps="false"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnVerLogs"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/card_bg"
            android:text="📋 Ver Logs"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:textAllCaps="false"
            android:layout_marginBottom="8dp" />

        <!-- Logs Section (hidden by default) -->
        <LinearLayout
            android:id="@+id/layoutLogs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_bg"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginBottom="12dp"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="📋 Logs de Hoje"
                android:textSize="16sp"
                android:textColor="@color/accent_cyan"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="300dp">

                <TextView
                    android:id="@+id/tvLogs"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Nenhum log."
                    android:textSize="11sp"
                    android:textColor="@color/text_secondary"
                    android:fontFamily="monospace" />
            </ScrollView>

            <Button
                android:id="@+id/btnLimparLogs"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/btn_danger"
                android:text="Limpar Logs"
                android:textColor="@color/white"
                android:textSize="12sp"
                android:textAllCaps="false"
                android:paddingLeft="16dp"
                android:paddingRight="16dp" />
        </LinearLayout>

        <!-- Spacer -->
        <View
            android:layout_width="match_parent"
            android:layout_height="40dp" />

    </LinearLayout>
</ScrollView>
