<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Valor Total a Dividir -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/card_bg"
        android:padding="12dp"
        android:layout_marginBottom="12dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Valor a Dividir"
            android:textColor="#B0BEC5"
            android:textSize="13sp"
            android:gravity="center" />

        <TextView
            android:id="@+id/tvValorDividir"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#00BCD4"
            android:textSize="28sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginTop="4dp" />
    </LinearLayout>

    <!-- Tipo de Divisao -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Tipo de Divisao:"
        android:textColor="#B0BEC5"
        android:textSize="13sp"
        android:layout_marginBottom="4dp" />

    <RadioGroup
        android:id="@+id/rgTipoDivisao"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">

        <RadioButton
            android:id="@+id/rbIgual"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Partes Iguais"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:checked="true" />

        <RadioButton
            android:id="@+id/rbPersonalizado"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Personalizado"
            android:textColor="#FFFFFF"
            android:textSize="14sp" />
    </RadioGroup>

    <!-- Selecione as Formas -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Selecione as formas de pagamento:"
        android:textColor="#B0BEC5"
        android:textSize="13sp"
        android:layout_marginBottom="8dp" />

    <!-- Lista de formas com checkboxes (gerada dinamicamente) -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:minHeight="120dp"
        android:maxHeight="300dp">

        <LinearLayout
            android:id="@+id/layoutFormasDivisao"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />
    </ScrollView>

    <!-- Resumo da divisao -->
    <LinearLayout
        android:id="@+id/layoutResumoDivisao"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/card_bg"
        android:padding="10dp"
        android:layout_marginTop="12dp"
        android:visibility="gone">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Resumo da Divisao"
            android:textColor="#00BCD4"
            android:textSize="14sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="6dp" />

        <LinearLayout
            android:id="@+id/layoutResumoItens"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#2A2F5A"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="6dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Total Distribuido:"
                android:textColor="#B0BEC5"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tvTotalDistribuido"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#00E676"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layoutDiferenca"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="2dp"
            android:visibility="gone">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Diferenca:"
                android:textColor="#FFFF5252"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tvDiferenca"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFFF5252"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
