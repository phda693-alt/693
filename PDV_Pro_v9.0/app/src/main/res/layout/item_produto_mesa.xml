<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:padding="6dp"
    android:background="@drawable/item_list_bg"
    android:layout_marginBottom="2dp">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvProdutoNome"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Produto"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvProdutoDetalhe"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1x R$ 10,00 = R$ 10,00"
            android:textColor="#B0BEC5"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/tvAdicionaisInfo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#00BCD4"
            android:textSize="10sp"
            android:visibility="gone" />
    </LinearLayout>

    <Button
        android:id="@+id/btnRemoverProduto"
        android:layout_width="38dp"
        android:layout_height="38dp"
        android:background="@drawable/btn_danger"
        android:text="X"
        android:textColor="#FFFFFF"
        android:textSize="10sp"
        android:padding="0dp" />
</LinearLayout>
