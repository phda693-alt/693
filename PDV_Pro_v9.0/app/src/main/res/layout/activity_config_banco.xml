<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/gradient_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Configuracao do Banco"
            android:textSize="24sp"
            android:textColor="@color/accent_cyan"
            android:textStyle="bold"
            android:layout_marginBottom="24dp" />

        <EditText android:id="@+id/etHost" android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="Host (IP ou dominio)" android:textColor="@color/text_primary" android:textColorHint="@color/text_hint"
            android:background="@drawable/input_bg" android:padding="16dp" android:layout_marginBottom="8dp" android:inputType="text" />

        <EditText android:id="@+id/etPorta" android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="Porta (padrao: 3306)" android:textColor="@color/text_primary" android:textColorHint="@color/text_hint"
            android:background="@drawable/input_bg" android:padding="16dp" android:layout_marginBottom="8dp" android:inputType="number" />

        <EditText android:id="@+id/etDatabase" android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="Nome do Banco de Dados" android:textColor="@color/text_primary" android:textColorHint="@color/text_hint"
            android:background="@drawable/input_bg" android:padding="16dp" android:layout_marginBottom="8dp" android:inputType="text" />

        <EditText android:id="@+id/etUsername" android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="Usuario do Banco" android:textColor="@color/text_primary" android:textColorHint="@color/text_hint"
            android:background="@drawable/input_bg" android:padding="16dp" android:layout_marginBottom="8dp" android:inputType="text" />

        <EditText android:id="@+id/etPassword" android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="Senha do Banco" android:textColor="@color/text_primary" android:textColorHint="@color/text_hint"
            android:background="@drawable/input_bg" android:padding="16dp" android:layout_marginBottom="16dp" android:inputType="textPassword" />

        <Button android:id="@+id/btnTestar" android:layout_width="match_parent" android:layout_height="48dp"
            android:text="TESTAR CONEXAO" android:textColor="@color/white" android:background="@drawable/btn_secondary"
            android:layout_marginBottom="8dp" />

        <Button android:id="@+id/btnSalvar" android:layout_width="match_parent" android:layout_height="48dp"
            android:text="SALVAR" android:textColor="@color/white" android:background="@drawable/btn_primary" />

        <TextView android:id="@+id/tvLocalIp" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:text="IP deste aparelho: verificando..."
            android:textColor="@color/accent_cyan" android:textSize="14sp"
            android:gravity="center" android:padding="12dp" android:layout_marginTop="8dp" />
    </LinearLayout>
</ScrollView>
