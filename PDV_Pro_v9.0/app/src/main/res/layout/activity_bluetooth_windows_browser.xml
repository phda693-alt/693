<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/gradient_bg"
    android:orientation="vertical">

    <!-- Toolbar / Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/toolbar_gradient"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/btnVoltar"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_arrow_back"
                android:scaleType="centerInside"
                android:padding="4dp"
                android:background="?attr/selectableItemBackgroundBorderless" />

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_bluetooth_search"
                android:scaleType="centerInside"
                android:layout_marginLeft="8dp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Bluetooth Windows"
                android:textColor="#2196F3"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginLeft="10dp" />

            <ImageView
                android:id="@+id/btnRefresh"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_refresh"
                android:scaleType="centerInside"
                android:padding="4dp"
                android:background="?attr/selectableItemBackgroundBorderless" />
        </LinearLayout>

        <!-- Status / Info -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="10dp"
            android:gravity="center_vertical">

            <View
                android:id="@+id/viewStatusIndicator"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:background="@drawable/circle_bg"
                android:layout_marginRight="8dp" />

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Pronto para buscar dispositivos Bluetooth"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Info text -->
        <TextView
            android:id="@+id/tvInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Busca computadores Windows com Bluetooth para imprimir via impressoras compartilhadas"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:layout_marginTop="6dp" />
    </LinearLayout>

    <!-- Painel de nivel de navegacao -->
    <LinearLayout
        android:id="@+id/layoutNivelInfo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="10dp"
        android:background="#0D1B3E"
        android:gravity="center_vertical"
        android:visibility="gone">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_bluetooth"
            android:scaleType="centerInside"
            android:layout_marginRight="8dp" />

        <TextView
            android:id="@+id/tvNivelPath"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text=""
            android:textColor="#2196F3"
            android:textSize="13sp"
            android:textStyle="bold"
            android:singleLine="true"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/tvNivelDesc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="@color/text_secondary"
            android:textSize="11sp" />
    </LinearLayout>

    <!-- Credenciais SMB (para acesso ao Windows) -->
    <LinearLayout
        android:id="@+id/layoutCredenciais"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp"
        android:background="#0D1B3E"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Credenciais do Windows (opcional)"
            android:textColor="#2196F3"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <EditText
                android:id="@+id/etDomain"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:hint="Dominio"
                android:text="WORKGROUP"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint"
                android:background="@drawable/input_bg"
                android:padding="8dp"
                android:textSize="13sp"
                android:layout_marginRight="6dp"
                android:singleLine="true" />

            <EditText
                android:id="@+id/etUser"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:hint="Usuario"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint"
                android:background="@drawable/input_bg"
                android:padding="8dp"
                android:textSize="13sp"
                android:layout_marginRight="6dp"
                android:singleLine="true" />

            <EditText
                android:id="@+id/etPassword"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:hint="Senha"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint"
                android:background="@drawable/input_bg"
                android:padding="8dp"
                android:textSize="13sp"
                android:inputType="textPassword"
                android:singleLine="true" />
        </LinearLayout>
    </LinearLayout>

    <!-- Botao de busca principal -->
    <Button
        android:id="@+id/btnBuscar"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="BUSCAR DISPOSITIVOS BLUETOOTH"
        android:textColor="@color/white"
        android:background="@drawable/btn_bluetooth"
        android:textSize="14sp"
        android:textStyle="bold"
        android:layout_margin="12dp"
        android:drawableLeft="@drawable/ic_bluetooth_search"
        android:drawablePadding="8dp" />

    <!-- Loading indicator -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="match_parent"
        android:layout_height="4dp"
        style="@android:style/Widget.ProgressBar.Horizontal"
        android:indeterminate="true"
        android:visibility="gone" />

    <!-- Lista de dispositivos -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp"
        android:clipToPadding="false" />

    <!-- Empty state -->
    <LinearLayout
        android:id="@+id/layoutEmpty"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone">

        <ImageView
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:src="@drawable/ic_bluetooth_search"
            android:alpha="0.4" />

        <TextView
            android:id="@+id/tvEmpty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nenhum dispositivo Bluetooth encontrado"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:layout_marginTop="12dp"
            android:gravity="center" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Verifique se o Bluetooth esta ativado\ne se o computador Windows esta visivel"
            android:textColor="@color/text_hint"
            android:textSize="12sp"
            android:layout_marginTop="4dp"
            android:gravity="center" />
    </LinearLayout>

    <!-- Bottom bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:background="#0D1B3E"
        android:gravity="center_vertical">

        <Button
            android:id="@+id/btnNivelAnterior"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_weight="1"
            android:text="VOLTAR NIVEL"
            android:textColor="@color/text_primary"
            android:background="@drawable/card_bg"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginRight="8dp"
            android:drawableLeft="@drawable/ic_arrow_back"
            android:drawablePadding="6dp"
            android:paddingLeft="12dp"
            android:visibility="gone" />

        <Button
            android:id="@+id/btnCancelar"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_weight="1"
            android:text="CANCELAR"
            android:textColor="@color/text_primary"
            android:background="@drawable/card_bg"
            android:textSize="13sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
