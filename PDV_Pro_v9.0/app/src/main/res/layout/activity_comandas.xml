<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/gradient_bg"
    android:orientation="vertical"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="12dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Comandas"
            android:textSize="22sp"
            android:textColor="@color/accent_cyan"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnAssistenteComandas"
            android:layout_width="wrap_content"
            android:layout_height="42dp"
            android:text="Assistente"
            android:textColor="@color/dark_bg"
            android:textSize="11sp"
            android:textAllCaps="false"
            android:background="@drawable/btn_gold"
            android:layout_marginEnd="6dp"
            android:paddingLeft="10dp"
            android:paddingRight="10dp" />

        <Button
            android:id="@+id/btnNovaComanda"
            android:layout_width="wrap_content"
            android:layout_height="42dp"
            android:text="+ Nova"
            android:textColor="@color/white"
            android:textSize="13sp"
            android:textAllCaps="false"
            android:background="@drawable/btn_primary"
            android:paddingLeft="16dp"
            android:paddingRight="16dp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">

        <Button
            android:id="@+id/btnFiltroAbertas"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:text="Abertas"
            android:textColor="@color/white"
            android:textSize="12sp"
            android:textAllCaps="false"
            android:background="@drawable/btn_primary"
            android:layout_marginEnd="4dp" />

        <Button
            android:id="@+id/btnFiltroTodas"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:text="Todas"
            android:textColor="@color/white"
            android:textSize="12sp"
            android:textAllCaps="false"
            android:background="@drawable/btn_secondary"
            android:layout_marginStart="4dp" />
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvComandas"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <TextView
        android:id="@+id/tvEmpty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Nenhuma comanda encontrada"
        android:textColor="@color/text_secondary"
        android:textSize="16sp"
        android:gravity="center"
        android:padding="32dp"
        android:visibility="gone" />

</LinearLayout>
