<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="@drawable/item_list_bg"
    android:minHeight="76dp"
    android:padding="13dp"
    android:layout_marginBottom="8dp"
    android:gravity="center_vertical">

    <ImageView
        android:id="@+id/ivFoto"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:scaleType="centerCrop"
        android:visibility="gone"
        android:background="@drawable/input_bg"
        android:padding="1dp"
        android:layout_marginRight="12dp" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvLine1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:textStyle="bold"
            android:lineSpacingExtra="2dp" />

        <TextView
            android:id="@+id/tvLine2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:layout_marginTop="3dp"
            android:lineSpacingExtra="2dp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/llBotoes"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginLeft="8dp">

        <Button
            android:id="@+id/btnDuplicar"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:text="Duplicar"
            android:textSize="11sp"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:background="@drawable/btn_secondary"
            android:paddingLeft="12dp"
            android:paddingTop="0dp"
            android:paddingRight="12dp"
            android:paddingBottom="0dp"
            android:layout_marginRight="6dp"
            android:visibility="gone" />

        <Button
            android:id="@+id/btnEditar"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:text="Editar"
            android:textSize="11sp"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:background="@drawable/btn_primary"
            android:paddingLeft="12dp"
            android:paddingTop="0dp"
            android:paddingRight="12dp"
            android:paddingBottom="0dp"
            android:layout_marginRight="6dp" />

        <Button
            android:id="@+id/btnInativar"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:text="Inativar"
            android:textSize="11sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:background="@drawable/btn_danger"
            android:paddingLeft="12dp"
            android:paddingTop="0dp"
            android:paddingRight="12dp"
            android:paddingBottom="0dp" />
    </LinearLayout>
</LinearLayout>
