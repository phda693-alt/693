<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/gradient_bg"
    android:padding="16dp">

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Pagamento" android:textSize="24sp" android:textColor="@color/accent_cyan"
        android:textStyle="bold" android:layout_marginBottom="12dp" />

    <!-- Card de Resumo de Valores -->
    <LinearLayout
        android:id="@+id/cardValorRestante"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/card_valor_restante"
        android:padding="16dp"
        android:layout_marginBottom="8dp">

        <!-- Total da Venda -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Total da Venda:"
                android:textColor="@color/text_secondary"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvTotalVenda"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Total Pago -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="6dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Total Pago:"
                android:textColor="@color/text_secondary"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvTotalPago"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#00E676"
                android:textSize="16sp"
                android:textStyle="bold"
                android:text="R$ 0,00" />
        </LinearLayout>

        <!-- Barra de Progresso -->
        <ProgressBar
            android:id="@+id/progressPagamento"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="12dp"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="10dp"
            android:max="1000"
            android:progress="0"
            android:progressDrawable="@drawable/progress_pagamento" />

        <!-- Porcentagem -->
        <TextView
            android:id="@+id/tvPorcentagem"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:text="0% pago" />

        <!-- Separador -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#2A2F5A"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="10dp" />

        <!-- VALOR RESTANTE - Destaque principal -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvLabelRestante"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="VALOR RESTANTE:"
                android:textColor="#FFFF5252"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvValorRestante"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFFF5252"
                android:textSize="24sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Troco (aparece quando pago a mais) -->
        <LinearLayout
            android:id="@+id/layoutTroco"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="6dp"
            android:visibility="gone">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="TROCO:"
                android:textColor="@color/accent_gold"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvTroco"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/accent_gold"
                android:textSize="20sp"
                android:textStyle="bold" />
        </LinearLayout>

    </LinearLayout>

    <!-- Saldo Devedor (hidden, mantido para compatibilidade) -->
    <TextView android:id="@+id/tvSaldoDevedor" android:layout_width="match_parent" android:layout_height="wrap_content"
        android:visibility="gone" android:textSize="1sp" />

    <!-- Botoes de Acao: Adicionar, Dividir e Para Entrega -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="4dp">

        <Button android:id="@+id/btnAddPagamento"
            android:layout_width="0dp"
            android:layout_height="64dp"
            android:minHeight="64dp"
            android:layout_weight="1"
            android:text="+ ADICIONAR"
            android:textColor="@color/white"
            android:textSize="11sp"
            android:singleLine="false"
            android:maxLines="2"
            android:gravity="center"
            android:includeFontPadding="false"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:textStyle="bold"
            android:background="@drawable/btn_secondary"
            android:layout_marginEnd="3dp" />

        <Button android:id="@+id/btnDividirPagamento"
            android:layout_width="0dp"
            android:layout_height="64dp"
            android:minHeight="64dp"
            android:layout_weight="1"
            android:text="DIVIDIR"
            android:textColor="@color/white"
            android:textSize="11sp"
            android:singleLine="false"
            android:maxLines="2"
            android:gravity="center"
            android:includeFontPadding="false"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:textStyle="bold"
            android:background="@drawable/btn_dividir"
            android:layout_marginStart="3dp"
            android:layout_marginEnd="3dp" />

        <Button android:id="@+id/btnParaEntrega"
            android:layout_width="0dp"
            android:layout_height="64dp"
            android:minHeight="64dp"
            android:layout_weight="1"
            android:text="PARA\nENTREGA"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:singleLine="false"
            android:maxLines="2"
            android:gravity="center"
            android:includeFontPadding="false"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:textStyle="bold"
            android:background="@drawable/btn_delivery"
            android:layout_marginStart="3dp" />
    </LinearLayout>

    <!-- Card de Entrega (visivel quando PARA ENTREGA ativado) -->
    <LinearLayout
        android:id="@+id/layoutEntregaInfo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/card_bg"
        android:padding="12dp"
        android:layout_marginTop="6dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="ENTREGA ATIVADA"
                android:textColor="#FF6D00"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvTaxaEntregaValor"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FF6D00"
                android:textSize="14sp"
                android:textStyle="bold"
                android:text="Taxa: R$ 0,00" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvBairroEntrega"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:layout_marginTop="4dp"
            android:text="Bairro: Nenhum selecionado" />

        <TextView
            android:id="@+id/tvEnderecoEntrega"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:layout_marginTop="2dp"
            android:text="Endereco do cliente" />
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvPagamentos"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="8dp" />

    <EditText android:id="@+id/etValorRecebido" android:layout_width="match_parent" android:layout_height="wrap_content"
        android:hint="Valor Recebido (opcional)" android:textColor="@color/text_primary" android:textColorHint="@color/text_hint"
        android:background="@drawable/input_bg" android:padding="12dp" android:inputType="numberDecimal"
        android:layout_marginTop="8dp" />

    <!-- v8.0.12.5 - Opcoes persistentes de impressao -->
    <LinearLayout
        android:id="@+id/layoutOpcoesImpressaoPagamento"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="8dp"
        android:paddingStart="4dp"
        android:paddingEnd="4dp">

        <CheckBox
            android:id="@+id/cbImprimirCanhotoSenha"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:buttonTint="@color/accent_cyan"
            android:checked="false"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:text="Imprimir canhoto de senha"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:textStyle="bold" />

        <CheckBox
            android:id="@+id/cbImprimirDuasViasCupom"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:buttonTint="@color/accent_cyan"
            android:checked="false"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:text="Imprimir 2 vias do cupom"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:textStyle="bold" />

        <CheckBox
            android:id="@+id/cbExibirSenhaNoCupom"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:buttonTint="@color/accent_cyan"
            android:checked="false"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:text="Exibir senha no cupom"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>

    <Button android:id="@+id/btnFinalizar" android:layout_width="match_parent" android:layout_height="52dp"
        android:text="FINALIZAR VENDA" android:textColor="@color/white" android:textSize="18sp" android:textStyle="bold"
        android:background="@drawable/btn_primary" android:layout_marginTop="12dp" />
</LinearLayout>
