<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Valor Restante no topo do dialog -->
    <LinearLayout
        android:id="@+id/layoutRestanteDialog"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/card_bg"
        android:padding="12dp"
        android:layout_marginBottom="12dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Valor Restante"
            android:textColor="#B0BEC5"
            android:textSize="13sp"
            android:gravity="center" />

        <TextView
            android:id="@+id/tvRestanteDialog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#FFFF5252"
            android:textSize="28sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginTop="4dp" />
    </LinearLayout>

    <EditText
        android:id="@+id/etValorPagamento"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Valor"
        android:inputType="numberDecimal"
        android:padding="12dp"
        android:textSize="18sp"
        android:layout_marginBottom="8dp" />

    <Spinner
        android:id="@+id/spParcelas"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:visibility="gone" />
</LinearLayout>
