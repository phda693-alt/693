<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="@drawable/item_list_bg"
    android:minHeight="92dp"
    android:padding="13dp"
    android:layout_marginBottom="8dp"
    android:gravity="center_vertical">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvLine1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:textStyle="bold"
            android:lineSpacingExtra="2dp" />

        <TextView
            android:id="@+id/tvLine2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:layout_marginTop="3dp"
            android:lineSpacingExtra="2dp" />

        <!-- v8.0.8 - Linha de rastreamento de usuarios (abertura e fechamento) -->
        <TextView
            android:id="@+id/tvLine3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_hint"
            android:textSize="10sp"
            android:textStyle="italic"
            android:layout_marginTop="3dp"
            android:visibility="gone" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginLeft="8dp">

        <Button
            android:id="@+id/btnVerOS"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:text="Ver"
            android:textSize="10sp"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:background="@drawable/btn_secondary"
            android:paddingLeft="8dp"
            android:paddingTop="0dp"
            android:paddingRight="8dp"
            android:paddingBottom="0dp"
            android:layout_marginRight="4dp" />

        <Button
            android:id="@+id/btnImprimir"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:text="Imprimir"
            android:textSize="10sp"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:background="@drawable/btn_primary"
            android:paddingLeft="8dp"
            android:paddingTop="0dp"
            android:paddingRight="8dp"
            android:paddingBottom="0dp"
            android:layout_marginRight="4dp" />

        <Button
            android:id="@+id/btnEditar"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:text="Editar"
            android:textSize="10sp"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:background="@drawable/btn_primary"
            android:paddingLeft="8dp"
            android:paddingTop="0dp"
            android:paddingRight="8dp"
            android:paddingBottom="0dp"
            android:layout_marginRight="4dp" />

        <!-- v8.0.11 - Botão de WhatsApp -->
        <Button
            android:id="@+id/btnWhatsApp"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:text="WhatsApp"
            android:textSize="9sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:background="@drawable/btn_success"
            android:paddingLeft="8dp"
            android:paddingTop="0dp"
            android:paddingRight="8dp"
            android:paddingBottom="0dp"
            android:layout_marginRight="4dp" />

        <Button
            android:id="@+id/btnInativar"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:text="X"
            android:textSize="9sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:background="@drawable/btn_danger"
            android:paddingLeft="8dp"
            android:paddingTop="0dp"
            android:paddingRight="8dp"
            android:paddingBottom="0dp" />
    </LinearLayout>
</LinearLayout>
