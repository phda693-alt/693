<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardArmario"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="6dp"
    app:cardBackgroundColor="@color/colorCard"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:id="@+id/llArmarioContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp"
        android:gravity="center">

        <!-- Numero do armario -->
        <TextView
            android:id="@+id/tvArmarioNumero"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Armario 1"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold" />

        <!-- Status -->
        <TextView
            android:id="@+id/tvArmarioStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Livre"
            android:textColor="#4CAF50"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginTop="2dp" />

        <!-- Localizacao -->
        <TextView
            android:id="@+id/tvArmarioLocalizacao"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#B0BEC5"
            android:textSize="10sp"
            android:layout_marginTop="2dp"
            android:visibility="gone" />

        <!-- Cliente -->
        <TextView
            android:id="@+id/tvArmarioCliente"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#FFB74D"
            android:textSize="11sp"
            android:layout_marginTop="4dp"
            android:gravity="center"
            android:visibility="gone" />

        <!-- Hora de entrada -->
        <TextView
            android:id="@+id/tvArmarioHoraEntrada"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#B0BEC5"
            android:textSize="10sp"
            android:visibility="gone" />

        <!-- v7.0.2 - Hora de saida (fechamento da conta) -->
        <TextView
            android:id="@+id/tvArmarioHoraSaida"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#EF9A9A"
            android:textSize="10sp"
            android:visibility="gone" />

        <!-- Tempo de uso -->
        <TextView
            android:id="@+id/tvArmarioTempoUso"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#FFD700"
            android:textSize="11sp"
            android:textStyle="bold"
            android:layout_marginTop="2dp"
            android:visibility="gone" />

        <!-- Total consumo -->
        <TextView
            android:id="@+id/tvArmarioTotal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#FFD700"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginTop="4dp"
            android:visibility="gone" />

    </LinearLayout>
</androidx.cardview.widget.CardView>
