<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/colorBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="8dp"
        android:background="@color/colorGradientStart">

        <View
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:background="@color/colorSuccess" />

        <TextView
            android:id="@+id/tvStatusSenhasWeb"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Iniciando painel web de senhas..."
            android:textColor="@color/colorTextSecondary"
            android:textSize="12sp"
            android:layout_marginStart="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Painel Senhas Web"
            android:textColor="@color/accent_gold"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

    <ProgressBar
        android:id="@+id/progressBarSenhas"
        style="@android:style/Widget.ProgressBar.Horizontal"
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:progressTint="@color/accent_gold"
        android:progressBackgroundTint="@color/colorGradientStart"
        android:visibility="visible" />

    <WebView
        android:id="@+id/webViewSenhas"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />
</LinearLayout>
