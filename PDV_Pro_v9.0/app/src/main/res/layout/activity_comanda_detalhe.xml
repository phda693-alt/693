<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/gradient_bg"
    android:orientation="vertical">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/colorCard"
        android:padding="16dp"
        android:elevation="4dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvTituloComanda"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Comanda #1"
                android:textSize="20sp"
                android:textColor="@color/accent_cyan"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvStatusDetalhe"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ABERTA"
                android:textColor="@color/colorSuccess"
                android:textSize="14sp"
                android:textStyle="bold"
                android:background="@drawable/btn_secondary"
                android:paddingLeft="12dp"
                android:paddingRight="12dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvClienteDetalhe"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Cliente: Nao informado"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/tvDataDetalhe"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Aberta em: --"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:layout_marginTop="2dp" />
    </LinearLayout>

    <!-- Barcode/search area -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical">

        <EditText
            android:id="@+id/etCodigoBarrasComanda"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:hint="Codigo de barras / descricao"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint"
            android:textSize="14sp"
            android:background="@drawable/card_bg"
            android:padding="10dp"
            android:singleLine="true"
            android:imeOptions="actionSearch"
            android:inputType="text" />

        <ImageButton
            android:id="@+id/btnScanBarcodeComanda"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_barcode_scan"
            android:background="@drawable/btn_scanner"
            android:scaleType="centerInside"
            android:padding="8dp"
            android:layout_marginStart="6dp"
            android:contentDescription="Scanner" />

        <ImageButton
            android:id="@+id/btnBuscarProdutoComanda"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_search_network"
            android:background="@drawable/btn_scanner"
            android:scaleType="centerInside"
            android:padding="8dp"
            android:layout_marginStart="6dp"
            android:contentDescription="Buscar" />
    </LinearLayout>

    <!-- Action buttons -->
    <LinearLayout
        android:id="@+id/llBotoesComanda"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingLeft="12dp"
        android:paddingRight="12dp"
        android:paddingBottom="8dp">

        <Button
            android:id="@+id/btnAddItemComanda"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:text="+ Produto"
            android:textColor="@color/white"
            android:textSize="12sp"
            android:textAllCaps="false"
            android:background="@drawable/btn_primary"
            android:layout_marginEnd="4dp" />

        <Button
            android:id="@+id/btnEscolherClienteComanda"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:text="Cliente"
            android:textColor="@color/white"
            android:textSize="12sp"
            android:textAllCaps="false"
            android:background="@drawable/btn_secondary"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp" />

        <Button
            android:id="@+id/btnImprimirComanda"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:text="Imprimir"
            android:textColor="@color/white"
            android:textSize="12sp"
            android:textAllCaps="false"
            android:background="@drawable/btn_secondary"
            android:layout_marginStart="4dp" />
    </LinearLayout>

    <!-- Items list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvItensComanda"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp" />

    <!-- Footer with total and action -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/colorCard"
        android:padding="16dp"
        android:elevation="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Observacao: "
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />

            <EditText
                android:id="@+id/etObservacaoComanda"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:hint="Observacao da comanda"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint"
                android:textSize="13sp"
                android:background="@drawable/card_bg"
                android:padding="8dp"
                android:singleLine="true" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvTotalComandaDetalhe"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Total: R$ 0,00"
                android:textColor="@color/accent_gold"
                android:textSize="20sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnFecharComanda"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:text="Fechar e Pagar"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textAllCaps="false"
                android:background="@drawable/btn_primary"
                android:paddingLeft="24dp"
                android:paddingRight="24dp" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
