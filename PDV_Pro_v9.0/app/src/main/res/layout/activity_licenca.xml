<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/gradient_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Ativacao de Licenca" android:textSize="24sp" android:textColor="@color/accent_cyan"
            android:textStyle="bold" android:layout_marginBottom="24dp" />

        <!-- Card de Status da Licenca com Data de Vencimento -->
        <LinearLayout
            android:id="@+id/cardStatusLicenca"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_licenca_sem"
            android:padding="16dp"
            android:layout_marginBottom="16dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/tvStatusLicencaTitulo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Status da Licenca"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">

                <View
                    android:id="@+id/viewStatusIndicador"
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@drawable/status_open"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:id="@+id/tvStatusLicenca"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sem licenca"
                    android:textSize="16sp"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/colorDivider"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Data de Vencimento:  "
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary" />

                <TextView
                    android:id="@+id/tvDataVencimento"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--/--/----"
                    android:textSize="16sp"
                    android:textColor="@color/accent_gold"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutDiasRestantes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="4dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Dias restantes:  "
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary" />

                <TextView
                    android:id="@+id/tvDiasRestantes"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="16sp"
                    android:textColor="@color/colorSuccess"
                    android:textStyle="bold" />
            </LinearLayout>

        </LinearLayout>

        <TextView android:id="@+id/tvContraChave" android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Contra-Chave:" android:textSize="16sp" android:textColor="@color/accent_gold"
            android:background="@drawable/card_bg" android:padding="16dp" android:layout_marginBottom="16dp"
            android:textIsSelectable="true" />

        <EditText android:id="@+id/etChaveAtivacao" android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="Chave de Ativacao" android:textColor="@color/text_primary" android:textColorHint="@color/text_hint"
            android:background="@drawable/input_bg" android:padding="16dp" android:layout_marginBottom="8dp" />

        <!-- Campo de Data com Calendario (igual ao Gerador de Licencas) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <EditText android:id="@+id/etDataExpiracao"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Data de Expiracao (DD/MM/AAAA)"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint"
                android:background="@drawable/input_bg"
                android:padding="16dp"
                android:inputType="date"
                android:maxLength="10"
                android:layout_marginEnd="8dp" />

            <Button android:id="@+id/btnCalendario"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CALENDARIO"
                android:textColor="@color/white"
                android:textSize="11sp"
                android:textStyle="bold"
                android:background="@drawable/btn_primary"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:minHeight="48dp" />
        </LinearLayout>

        <Button android:id="@+id/btnAtivar" android:layout_width="match_parent" android:layout_height="48dp"
            android:text="ATIVAR LICENCA" android:textColor="@color/white" android:background="@drawable/btn_primary" />

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="@color/text_hint" android:layout_marginTop="32dp" android:layout_marginBottom="16dp" />

        <Button android:id="@+id/btnLimparLicenca" android:layout_width="match_parent" android:layout_height="48dp"
            android:text="LIMPAR TABELA LICENCA" android:textColor="#FFFFFF" android:background="@drawable/btn_danger"
            android:layout_marginTop="8dp" />
    </LinearLayout>
</ScrollView>
