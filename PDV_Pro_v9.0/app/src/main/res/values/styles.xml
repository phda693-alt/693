<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- === TEMA PRINCIPAL === -->
    <style name="AppTheme" parent="Theme.MaterialComponents.NoActionBar">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
        <item name="android:windowBackground">@color/colorBackground</item>
        <item name="android:statusBarColor">@color/colorBackground</item>
        <item name="android:navigationBarColor">@color/colorBackground</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textColorHint">@color/text_hint</item>
        <item name="materialButtonStyle">@style/ButtonPrimary</item>
        <item name="colorSurface">@color/colorSurface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorError">@color/colorDanger</item>
        <item name="android:windowAnimationStyle">@style/WindowAnimationStyle</item>
    </style>

    <!-- === ANIMAÇÃO DE JANELA === -->
    <style name="WindowAnimationStyle" parent="@android:style/Animation.Activity">
        <item name="android:activityOpenEnterAnimation">@anim/slide_in_right</item>
        <item name="android:activityOpenExitAnimation">@anim/slide_out_left</item>
        <item name="android:activityCloseEnterAnimation">@anim/slide_in_left</item>
        <item name="android:activityCloseExitAnimation">@anim/slide_out_right</item>
    </style>

    <!-- === TEMA SPLASH === -->
    <style name="SplashTheme" parent="Theme.MaterialComponents.NoActionBar">
        <item name="android:windowBackground">@color/colorSplashStart</item>
        <item name="android:statusBarColor">@color/colorSplashStart</item>
        <item name="android:navigationBarColor">@color/colorSplashStart</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
        <item name="android:windowFullscreen">false</item>
    </style>

    <!-- === BOTÕES === -->
    <style name="ButtonPrimary" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/colorPrimary</item>
        <item name="android:textColor">@color/colorBackground</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.02</item>
        <item name="android:minHeight">0dp</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:includeFontPadding">true</item>
        <item name="android:paddingTop">4dp</item>
        <item name="android:paddingBottom">4dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="elevation">4dp</item>
        <item name="rippleColor">@color/colorRipple</item>
    </style>

    <style name="ButtonSecondary" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">@color/colorPrimary</item>
        <item name="strokeWidth">1.5dp</item>
        <item name="android:textColor">@color/colorPrimary</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:minHeight">0dp</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:paddingTop">4dp</item>
        <item name="android:paddingBottom">4dp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="ButtonDanger" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/colorDanger</item>
        <item name="android:textColor">@color/white</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:minHeight">0dp</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:paddingTop">4dp</item>
        <item name="android:paddingBottom">4dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="rippleColor">@color/colorRippleDanger</item>
    </style>

    <style name="ButtonSuccess" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/colorSuccess</item>
        <item name="android:textColor">@color/colorBackground</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:minHeight">0dp</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:paddingTop">4dp</item>
        <item name="android:paddingBottom">4dp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="ButtonGold" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/colorGold</item>
        <item name="android:textColor">@color/colorBackground</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:minHeight">0dp</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:paddingTop">4dp</item>
        <item name="android:paddingBottom">4dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="rippleColor">@color/colorRippleGold</item>
    </style>

    <!-- === INPUT === -->
    <style name="InputStyle" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/colorNeon</item>
        <item name="hintTextColor">@color/colorNeon</item>
        <item name="android:textColorHint">@color/colorTextHint</item>
        <item name="boxBackgroundColor">@color/colorInputBg</item>
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
        <item name="boxStrokeWidth">1.5dp</item>
        <item name="boxStrokeWidthFocused">2dp</item>
    </style>

    <!-- === DASHBOARD BUTTON === -->
    <style name="DashboardButton">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_columnWeight">1</item>
        <item name="android:background">@drawable/dashboard_item_bg</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">11sp</item>
        <item name="android:gravity">center</item>
        <item name="android:paddingLeft">6dp</item>
        <item name="android:paddingRight">6dp</item>
        <item name="android:paddingTop">10dp</item>
        <item name="android:paddingBottom">10dp</item>
        <item name="android:layout_margin">5dp</item>
        <item name="android:drawablePadding">8dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:includeFontPadding">true</item>
        <item name="android:minHeight">110dp</item>
        <item name="android:letterSpacing">0</item>
    </style>

    <!-- === REPORT BUTTON === -->
    <style name="ReportButton">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">60dp</item>
        <item name="android:background">@drawable/card_bg</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">15sp</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:minHeight">60dp</item>
        <item name="android:includeFontPadding">true</item>
        <item name="android:paddingTop">4dp</item>
        <item name="android:paddingBottom">4dp</item>
        <item name="android:paddingLeft">16dp</item>
        <item name="android:paddingRight">16dp</item>
        <item name="android:layout_marginBottom">8dp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <!-- === DIAGNOSTIC === -->
    <style name="DiagnosticCard">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:background">@drawable/card_bg</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">13sp</item>
        <item name="android:lineSpacingExtra">4dp</item>
        <item name="android:padding">16dp</item>
        <item name="android:layout_marginBottom">10dp</item>
    </style>

    <style name="DiagnosticActionButton">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">90dp</item>
        <item name="android:layout_columnWeight">1</item>
        <item name="android:background">@drawable/dashboard_item_bg</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">12sp</item>
        <item name="android:gravity">center</item>
        <item name="android:paddingLeft">6dp</item>
        <item name="android:paddingRight">6dp</item>
        <item name="android:paddingTop">6dp</item>
        <item name="android:paddingBottom">6dp</item>
        <item name="android:layout_margin">4dp</item>
        <item name="android:drawablePadding">6dp</item>
        <item name="android:includeFontPadding">true</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <!-- === SECTION HEADER === -->
    <style name="SectionHeader">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/accent_gold</item>
        <item name="android:textSize">11sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.12</item>
        <item name="android:layout_marginTop">20dp</item>
        <item name="android:layout_marginBottom">8dp</item>
        <item name="android:paddingStart">8dp</item>
        <item name="android:paddingEnd">8dp</item>
        <item name="android:textAllCaps">true</item>
    </style>

    <!-- === CARD STYLE === -->
    <style name="CardStyle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:background">@drawable/card_bg</item>
        <item name="android:padding">16dp</item>
        <item name="android:layout_marginBottom">8dp</item>
    </style>

    <!-- === TOOLBAR === -->
    <style name="ToolbarStyle" parent="Widget.MaterialComponents.Toolbar">
        <item name="android:background">@drawable/toolbar_gradient</item>
        <item name="titleTextColor">@color/text_primary</item>
        <item name="android:elevation">8dp</item>
    </style>

    <!-- === DIALOG === -->
    <style name="DialogTheme" parent="Theme.MaterialComponents.Dialog">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="android:windowBackground">@color/colorCard</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="colorSurface">@color/colorCard</item>
        <item name="colorOnSurface">@color/text_primary</item>
    </style>

    <!-- === BADGE === -->
    <style name="BadgeStyle">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:background">@drawable/circle_bg</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">10sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:padding">4dp</item>
        <item name="android:minWidth">20dp</item>
        <item name="android:gravity">center</item>
    </style>

    <!-- ===================================================================== -->
    <!-- v9.1.0 - ESTILOS FUTURISTAS ADICIONAIS (apenas adicoes)               -->
    <!-- ===================================================================== -->

    <!-- Botao com gradiente aurora (ciano -> azul -> roxo) -->
    <style name="ButtonAurora" parent="Widget.MaterialComponents.Button">
        <item name="android:background">@drawable/btn_aurora_bg</item>
        <item name="backgroundTint">@null</item>
        <item name="android:textColor">@color/colorBackground</item>
        <item name="cornerRadius">14dp</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.03</item>
        <item name="android:minHeight">0dp</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:paddingTop">6dp</item>
        <item name="android:paddingBottom">6dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="elevation">6dp</item>
    </style>

    <!-- Cartao glassmorphism elevado -->
    <style name="GlassCard">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:background">@drawable/glass_card_bg</item>
        <item name="android:padding">18dp</item>
        <item name="android:layout_marginBottom">10dp</item>
        <item name="android:elevation">6dp</item>
    </style>

    <!-- Titulo com brilho/realce neon -->
    <style name="NeonTitle">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/colorNeonEdge</item>
        <item name="android:textSize">20sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.04</item>
        <item name="android:shadowColor">@color/colorNeonGlow</item>
        <item name="android:shadowDx">0</item>
        <item name="android:shadowDy">0</item>
        <item name="android:shadowRadius">14</item>
    </style>

    <!-- Divisor neon reutilizavel -->
    <style name="NeonDivider">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">2dp</item>
        <item name="android:background">@drawable/neon_divider</item>
        <item name="android:layout_marginTop">8dp</item>
        <item name="android:layout_marginBottom">8dp</item>
    </style>
</resources>
