<?xml version="1.0" encoding="utf-8"?>
<!-- v9.1.0 - Cartao do dashboard com acabamento de vidro futurista (glassmorphism).
     Mantem o tom escuro original (#1A2230) como base e adiciona profundidade,
     gradiente diagonal sutil e borda com leve brilho ciano. -->
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="#3300E5CC">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#222D40"
                android:centerColor="#1A2230"
                android:endColor="#141B27"
                android:angle="135"
                android:type="linear" />
            <corners android:radius="18dp" />
            <stroke android:width="1dp" android:color="#2E4A60" />
        </shape>
    </item>
</ripple>
